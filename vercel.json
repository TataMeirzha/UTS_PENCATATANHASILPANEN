{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "rewrites": [
        { "source": "/api/:path*.php", "destination": "/api/:path*.php" },
        { "source": "/", "destination": "/index.html" },
        { "source": "/(.*)", "destination": "/$1" }
    ]
}